on after_initialization do
  add_rule("Fan", "Half Flush", "(Half Flush) You get 1 Fan if your hand has only tiles of one suit, plus honours. This is always awarded.", -10)
end

define_yaku yaku, "Half Flush", [1, "Fan"], winning_hand_consists_of("1p","2p","3p","4p","5p","6p","7p","8p","9p","1z","2z","3z","4z","8z","6z","7z")
