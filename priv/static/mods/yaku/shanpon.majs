on after_initialization do
  add_rule("$value $han", "$name", "%{value} %{han} if your final wait contains at least two pairs waiting for either one to become a triplet.", %{value: !value, han: !han, name: !name})
  add_rule("$value $han", "$name", "%{example_hand}", %{value: !value, han: !han, name: !name, example_hand: ~t"456m12344p23499s 9s"})
end

define_set pair, ~s"0 0"
define_set mentsu, ~s"0 0 0 | 0 1 2"

define_yaku !list, !name, [!value, !han], match(["hand", "calls"], ~m"exhaustive, mentsu:3, pair:2")
