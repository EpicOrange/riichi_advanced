define_play_effect joker do
  set_status("discarded_joker")
end

define_button start_joker,
  display_name: "Replace joker",
  show_when: status("initial_flowers")
    and our_turn
    and match(["hand", "draw"], "any_joker")
  do
    big_text("Joker")
    flower(+@all_jokers)
    set_status("has_joker")
    draw(1, "opposite_end")
    recalculate_buttons
  end

define_button joker,
  display_name: "Replace joker",
  show_when: our_turn
    and has_draw
    and not_just_discarded
    and status_missing("initial_flowers", "just_called")
    and match(["hand", "draw"], "any_joker")
  do
    big_text("Joker")
    flower(+@all_jokers)
    set_status("flower")
    unset_status("kan")
    if no_tiles_remaining do
      advance_turn
    else
      draw(1, "opposite_end")
    end
  end

apply prepend, "buttons.ron.actions" do
  if match(["hand", "calls", "last_discard"], "any_joker") do
    set_status("has_joker")
  end
end
apply prepend, "buttons.chankan.actions" do
  if match(["hand", "calls", "last_called_tile"], "any_joker") do
    set_status("has_joker")
  end
end
apply prepend, "buttons.tsumo.actions" do
  if match(["hand", "calls", "draw"], "any_joker") do
    set_status("has_joker")
  end
end

on after_call do
  if match(["last_call"], ["any_joker"]) do
    set_status("has_joker")
  end
end

def calculate_joker_values do
  tong_value = 2
  thung_value = 1
  sooc_value = 1
  man_value = 1
  hoa_value = 2
  hi_value = 1
  nguyen_value = 1
  hop_value = 1
  if seat_is("east") or match(["start_jokers"], ~m"0j:1") do tong_value = 3 end
  if seat_is("south") do thung_value = 2 end
  if seat_is("west") do sooc_value = 2 end
  if seat_is("north") do man_value = 2 end
  if seat_is("south") do hi_value = 2 end
  if seat_is("west") do nguyen_value = 2 end
  if seat_is("north") or match(["start_jokers"], ~m"2j:1") do hop_value = 2 end
end
on before_win do
  calculate_joker_values
  multiply_counter("tong_value", "count_matches", ["jokers"], ~m"nojoker, (0j 00j 50j 80j):1")
  multiply_counter("thung_value", "count_matches", ["jokers"], ~m"nojoker, (6j 06j 56j 86j):1")
  multiply_counter("sooc_value", "count_matches", ["jokers"], ~m"nojoker, (7j 07j 57j 87j):1")
  multiply_counter("man_value", "count_matches", ["jokers"], ~m"nojoker, (8j 08j 58j 88j):1")
  multiply_counter("hoa_value", "count_matches", ["flowers"], ~m"nojoker, (9j 09j 59j 89j):1")
  multiply_counter("hi_value", "count_matches", ["jokers"], ~m"nojoker, (5j 05j 55j 85j):1")
  multiply_counter("nguyen_value", "count_matches", ["jokers"], ~m"nojoker, (4j 04j 54j 84j):1")
  multiply_counter("hop_value", "count_matches", ["jokers"], ~m"nojoker, (2j 02j 52j 82j):1")
end

# TODO need to be consistent abt what's in English and what's in Vietnamese
# set-aside blue jokers
define_yaku yaku, "Anything Joker (縂)", ["tong_value", "Phán"], tong_value > 0
define_yaku yaku, "Dot Joker (筒)", ["thung_value", "Phán"], thung_value > 0
define_yaku yaku, "Bamboo Joker (索)", ["sooc_value", "Phán"], sooc_value > 0
define_yaku yaku, "Character Joker (萬)", ["man_value", "Phán"], man_value > 0
# set-aside red jokers
define_yaku yaku, "Flower Joker (花)", ["hoa_value", "Phán"], hoa_value > 0
define_yaku yaku, "Wind Joker (喜)", ["hi_value", "Phán"], hi_value > 0
define_yaku yaku, "Dragon Joker (元)", ["nguyen_value", "Phán"], nguyen_value > 0
define_yaku yaku, "Number Joker (合)", ["hop_value", "Phán"], hop_value > 0

# joker set usage (add viet_more_jokers mod for more combos)
define_yaku yaku, "Blue Joker Set", [1, "Mủn"], match(["hand", "calls", "flowers", "jokers", "winning_tile"], ~m"nojoker, 0j:1, 6j:1, 7j:1, 8j:1")
define_yaku yaku, "Blue Joker Set", [1, "Mủn"], match(["flowers", "jokers"], ~m"nojoker, 0j:1, 6j:1, 7j:1, 8j:1")
define_yaku yaku, "Red Joker Set", [1, "Mủn"], match(["hand", "calls", "flowers", "jokers", "winning_tile"], ~m"nojoker, 2j:1, 4j:1, 5j:1, 9j:1")
define_yaku yaku, "Red Joker Set", [1, "Mủn"], match(["flowers", "jokers"], ~m"nojoker, 2j:1, 4j:1, 5j:1, 9j:1")

# win on discarded joker
define_yaku yaku, "Win on Discarded Joker", [1, "Mủn"], won_by_discard and match(["last_discard"], "any_joker")

# can't use too many jokers in calls
apply set_append, "buttons.chii.call_conditions", not_call_contains([+@all_jokers], 2)
apply set_append, "buttons.pon.call_conditions", not_call_contains([+@all_jokers], 2)
apply set_append, "buttons.daiminkan.call_conditions", not_call_contains([+@all_jokers], 1)
apply set_append, "buttons.kakan.call_conditions", not_call_contains([+@all_jokers], 1)
apply set_append, "buttons.ankan.call_conditions", not_call_contains([+@all_jokers], 1)

# for a simultaneous call, no jokers wins over weak jokers, weak jokers win over strong jokers
apply set_append, "buttons.pon.call_priority_list", not_call_choice_contains([+@all_jokers], 1)
apply set_append, "buttons.pon.call_priority_list", call_choice_contains([+@all_jokers_1], 1)
apply set_append, "buttons.pon.call_priority_list", call_choice_contains([+@all_jokers_2], 1)
apply set_append, "buttons.pon.call_priority_list", call_choice_contains([+@all_jokers_3], 1)
apply set_append, "buttons.daiminkan.call_priority_list", not_call_choice_contains([+@all_jokers], 1)
apply set_append, "buttons.daiminkan.call_priority_list", call_choice_contains([+@all_jokers_1], 1)
apply set_append, "buttons.daiminkan.call_priority_list", call_choice_contains([+@all_jokers_2], 1)
apply set_append, "buttons.daiminkan.call_priority_list", call_choice_contains([+@all_jokers_3], 1)

# bouncing jokers
on after_initialization do
  add_rule("Rules", "Bouncing Jokers", "If you have called Phỗng with a joker, and later you draw another copy of the same tile, you may 'bounce' the joker by substituting the joker for that drawn tile. The joker goes into your joker/flower pool as if replaced normally (scores points). You cannot bounce jokers when there are no more tiles remaining in the wall.")
end

define_button joker_swap,
  display_name: "Bounce joker",
  show_when: 
    our_turn and not_just_discarded
    and not_status("can_rob_bounce")
    and match(["hand_draw_nonjoker_any", "self_joker_meld_tiles"], ~m"pair:1")
    and not_no_tiles_remaining
  do
    big_text("Bounce")
    mark([["call", 1, ["call_has_joker", "match_call_to_marked_hand"]], ["hand", 1, ["self", "not_joker", "match_hand_to_marked_call"]]])
    set_status("can_rob_bounce")
    swap_out_joker(@all_jokers, "call")
    unset_status("can_rob_bounce")
    draw(1, "opposite_end")
  end
