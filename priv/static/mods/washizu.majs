if !transparents >= 4 do
  apply append, """
    wall[0,4,8,12,16,20,24,28,32,36,40,44,48,52,56,60,64,68,72,76,80,84,88,92,96,100,104,108,112,116,120,124,128,132,136,140,144,148,152,156,160,164,168,172,176,180,184,188,192,196,200,204,208,212,216,220,224,228,232,236,240,244,248,252,256,260,264,268,272276,280,284,288,292,296]\
    """, ["_revealed", "_transparent"]
end
# remove null tiles created by accessing invalid indices
apply delete, "wall", nil
apply delete, "wall", ["_revealed", "_transparent"]

# divide all scores by 10 (1000 pts -> 100 ccs)
apply merge, "score_calculation", %{
  score_denomination: "🩸",
  riichi_value: 100,
  honba_value: 10
}
apply divide, "initial_score", 10
apply divide, "score_calculation.tobi", 10
apply round_up, "score_calculation.tobi", 1
define_scoring ron do
  total /= 10 :: "Washizu"
end
define_scoring tsumo do
  total /= 10 :: "Washizu"
end
apply append, "functions.noten_payments" do
  as everyone do
    tenpai_points *= -0.9
    noten_points *= -0.9
    if status("tenpai") do
      modify_payout("self", "tenpai_points")
    else
      modify_payout("self", "noten_points")
    end
  end
end

