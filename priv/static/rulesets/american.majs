# TODO: check that this button behaves the way it should. this button is here for any variants where a player has so many unpassable tiles (e.g. jokers, blanks, flowers in older NMJL rules) that they are unable to pass three tiles during the Charleston.
# TODO: need some kind of test scenario to check if this button works correctly
define_button abort_during_charleston,
  display_name: "Can't pass three tiles",
  show_when: status("match_start") and passables < 3,
  precedence_over: ["charleston_left", "charleston_across", "charleston_right", "continue_charleston", "skip_charleston"],
  unskippable: true,
  cancellable: false
  do
    big_text("Can't pass three tiles")
    pause(1500)
    abortive_draw("Throw in all tiles and start again")
  end

# the prefixes 1_, 2_, 3_ are just to put the buttons in the correct order when shown
# but otherwise you refer to them as am_pung, etc. due to the call_name field
define_button "1_am_pung",
  display_name: "Pung",
  show_when: status_missing("match_start", "dead_hand") and not_our_turn and not_no_tiles_remaining and someone_else_just_discarded and call_available,
  precedence_over: ["am_pung", "am_kong", "am_quint"],
  call: [[0, 0]],
  call_name: "am_pung",
  call_conditions: hand_length_at_least(3)
    and not_called_tile_contains(["1j"], 1)
    # forgot what this last check is for
    and call_contains(["1m","2m","3m","4m","5m","6m","7m","8m","9m","1p","2p","3p","4p","5p","6p","7p","8p","9p","1s","2s","3s","4s","5s","6s","7s","8s","9s","1z","2z","3z","4z","0z","6z","7z","1f","2f","3f","4f","1g","2g","3g","4g"], 1)
  do
    big_text("Pung")
    call
    change_turn("self")
  end

define_button "2_am_kong",
  display_name: "Kong",
  show_when: status_missing("match_start", "dead_hand") and not_our_turn and not_no_tiles_remaining and someone_else_just_discarded and call_available,
  precedence_over: ["am_pung", "am_kong", "am_quint"],
  call: [[0, 0, 0]],
  call_name: "am_kong",
  call_conditions: hand_length_at_least(4)
    and not_called_tile_contains(["1j"], 1)
    and call_contains(["1m","2m","3m","4m","5m","6m","7m","8m","9m","1p","2p","3p","4p","5p","6p","7p","8p","9p","1s","2s","3s","4s","5s","6s","7s","8s","9s","1z","2z","3z","4z","0z","6z","7z","1f","2f","3f","4f","1g","2g","3g","4g"], 1)
  do
    big_text("Kong")
    call
    change_turn("self")
  end

define_button "3_am_quint",
  display_name: "Quint",
  show_when: status_missing("match_start", "dead_hand") and not_our_turn and not_no_tiles_remaining and someone_else_just_discarded and call_available,
  precedence_over: ["am_pung", "am_kong", "am_quint"],
  call: [[0, 0, 0, 0]],
  call_name: "am_quint",
  call_conditions: hand_length_at_least(5)
    and not_called_tile_contains(["1j"], 1)
    and call_contains(["1m","2m","3m","4m","5m","6m","7m","8m","9m","1p","2p","3p","4p","5p","6p","7p","8p","9p","1s","2s","3s","4s","5s","6s","7s","8s","9s","1z","2z","3z","4z","0z","6z","7z","1f","2f","3f","4f","1g","2g","3g","4g"], 1)
  do
    big_text("Quint")
    call
    change_turn("self")
  end

define_button am_joker_swap,
  display_name: "Swap for exposed joker",
  show_when: status_missing("match_start", "dead_hand") and our_turn and not_just_discarded and match(["hand_draw_nonjoker_any", "anyone_joker_meld_tiles"], ~m"pair:1")
  do
    big_text("Swap")
    mark [["call", 1, ["call_has_joker", "match_call_to_marked_hand"]],
          ["hand", 1, ["self", "not_joker", "match_hand_to_marked_call"]]]
    swap_out_joker("1j")
  end

define_button mahjong_heavenly,
  display_name: "Mah Jongg",
  show_when: status("heavenly_available", "charleston_left") and our_turn and is_tenpai_american and match(["hand", "call_tiles", "draw"], ["win"]),
  precedence_over: ["am_pung", "am_kong", "am_quint", "abort_during_charleston"]
  do
    big_text("Mah Jongg")
    pause(1000)
    reveal_hand
    win_by_draw("win")
  end

