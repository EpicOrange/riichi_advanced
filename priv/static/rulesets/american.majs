      if status("charleston_across_1") do unset_status("charleston_across_2", as: "prev_seat"); set_status("charleston_across_1", as: "prev_seat") end
      if status("charleston_across_3") do unset_status("charleston_across_3"); set_status("charleston_across_2") end
    end
