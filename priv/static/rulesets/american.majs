define_auto_button _1_auto_sort,
  display_name: "A",
  desc: "Automatically sort your hand.",
  enabled_at_start: true
  do
    sort_hand
  end

define_auto_button _2_auto_ron,
  display_name: "M",
  desc: "Automatically declare Mah Jongg."
  do
    if buttons_include("mahjong_discard") do press_button("mahjong_discard") end
    if buttons_include("mahjong_draw") do press_button("mahjong_draw") end
    if buttons_include("mahjong_heavenly") do press_button("mahjong_heavenly") end
  end

define_auto_button _3_auto_no_call,
  display_name: "C",
  desc: "Skip all calls except Mah Jongg."
  do
    if not_our_turn and buttons_include("skip") and buttons_exclude("mahjong_discard", "mahjong_heavenly", "am_joker_swap") do
      press_button("skip")
    end
  end

define_auto_button _4_auto_no_call,
  display_name: "JC",
  desc: "Skip calls that only use your jokers."
  do
    if not_our_turn and buttons_include("skip") and buttons_exclude("mahjong_discard", "mahjong_heavenly", "am_joker_swap")
        and (not_match(["hand"], ~m"nojoker, (1f 2f 3f 4f 1g 2g 3g 4g):1") or not_match(["last_discard"], ~m"nojoker, (1f 2f 3f 4f 1g 2g 3g 4g):1"))
        and not_match(["last_discard", "hand_any"], ~m"nojoker, pair:1") do
      press_button("skip")
    end
  end

define_auto_button _5_auto_no_dead_call,
  display_name: "DC",
  desc: "Skip calls that deaden your hand.",
  enabled_at_start: true
  do
    if not_our_turn and buttons_include("skip") and buttons_exclude("mahjong_discard", "mahjong_heavenly", "am_joker_swap") and all_calls_deaden_hand do
      press_button("skip")
    end
  end

define_auto_button _6_auto_discard,
  display_name: "D",
  desc: "Automatically discard your drawn tile."
  do
    if our_turn and has_draw and buttons_exclude("am_joker_swap", "mahjong_draw", "mahjong_heavenly") do
      discard_draw
    end
  end

define_auto_button _6_auto_discard,
  display_name: "DD",
  desc: "Automatically discard your drawn tile if it doesn't match any of your hand tiles."
  do
    if has_draw
        and buttons_exclude("am_joker_swap", "mahjong_draw", "mahjong_heavenly")
        and (not_match(["hand"], ~m"nojoker, (1f 2f 3f 4f 1g 2g 3g 4g):1") or not_match(["draw"], ~m"nojoker, (1f 2f 3f 4f 1g 2g 3g 4g):1"))
        and not_match(["draw"], ~m"nojoker, 1j:1")
        and not_match(["draw", "hand_any"], ~m"nojoker, pair:1") do
      discard_draw
    end
  end

set interruptible_actions, ["play_tile", "draw"]
set initial_score, 0
set starting_tiles, 13
set initial_dead_wall_length, 0
set four_rows_discards, true
set dead_hand_buttons, true
set max_rounds, 8
