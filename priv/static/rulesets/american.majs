      and (match(["hand", "call_tiles", "draw"], ["open_win"]) or (has_no_call_named("am_pung", "am_kong", "am_quint") and match(["hand", "call_tiles", "draw"], ["win"]))),
  precedence_over: ["am_pung", "am_kong", "am_quint"]
  do
    big_text("Mah Jongg")
    pause(1000)
    reveal_hand
    win_by_draw("win")
  end

define_button mahjong_discard,
  display_name: "Mah Jongg",
  show_when: status_missing("match_start", "dead_hand") and not_our_turn and not_just_discarded and someone_else_just_discarded and is_tenpai_american
      and not_match(["last_discard"], ~m"1j:1")
      and (match(["hand", "call_tiles", "last_discard"], ["open_win"]) or (has_no_call_named("am_pung", "am_kong", "am_quint") and match(["hand", "call_tiles", "last_discard"], ["win"]))),
  precedence_over: ["am_pung", "am_kong", "am_quint", "mahjong_discard"]
  do
    big_text("Mah Jongg")
    pause(1000)
    reveal_hand
    win_by_discard("win")
  end

# again, the 0_ and 1_ are to order the buttons
# TODO: Change push messages to mention player's names instead of just saying the player directions.
define_button declare_dead_0_shimocha,
  display_name: "Declare hand on right dead",
  show_when: status("declare_shimocha_dead") and status_missing("dead_hand") and our_turn,
  unskippable: true
  do
    unset_status("declare_shimocha_dead")
    if hand_is_dead("shimocha") do
      big_text("Dead hand", as: "shimocha")
      push_message("correctly declared player on right's hand dead")
      push_message("is now disqualified", as: "shimocha")
      set_status("dead_hand", as: "shimocha")
    else
      big_text("Not dead", as: "shimocha")
      big_text("Dead hand")
      push_message("incorrectly declared player on right's hand dead")
      push_message("is now disqualified")
      set_status("dead_hand")
      advance_turn
    end
    if toimen_status("dead_hand") and kamicha_status("dead_hand") do
      pause(1000)
      ryuukyoku("Three Dead Hands")
    end
  end

define_button declare_dead_0_toimen,
  display_name: "Declare hand across dead",
  show_when: status("declare_toimen_dead") and status_missing("dead_hand") and our_turn,
  unskippable: true
  do
    unset_status("declare_toimen_dead")
    if hand_is_dead("toimen") do
      big_text("Dead hand", as: "toimen")
      push_message("correctly declared opposite player's hand dead")
      push_message("is now disqualified", as: "toimen")
      set_status("dead_hand", as: "toimen")
    else
      big_text("Not dead", as: "toimen")
      big_text("Dead hand")
      push_message("incorrectly declared opposite player's hand dead")
      push_message("is now disqualified")
      set_status("dead_hand")
      advance_turn
    end
    if shimocha_status("dead_hand") and kamicha_status("dead_hand") do
      pause(1000)
      ryuukyoku("Three Dead Hands")
    end
  end

