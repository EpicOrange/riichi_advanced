  end

define_button final_charleston_offer_3,
  display_name: "Offer 3",
  show_when: passables >= 3 and status("final_charleston") and status_missing("charleston_across_0", "charleston_across_1", "charleston_across_2", "charleston_across_3"),
  unskippable: true
  do
