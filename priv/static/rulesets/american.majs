set score_calculation, %{
  yaku_lists: ["yaku"],
  use_smt: false,
  highest_scoring_yaku_only: true,
  arrange_american_yaku: true,
  point_name: "Pts",
  win_by_discard_label: "Discard",
  win_by_draw_label: "Draw",
  win_by_discard_name: "Mah Jongg",
  win_by_draw_name: "Mah Jongg",
  exhaustive_draw_name: "Draw"
}

define_scoring win do
  total = points :: "Pts"
  set_counter_all("hand_score", "total")
  if won_by_draw do
    total *= 2 :: "Self Draw"
  else
    if seat_is("last_discarder") do
      total *= 2 :: "Discarder penalty"
    end
  end
  # jokerless hand bonus
  if jokers == 0 and not_match(["hand", "call_tiles", "winning_tile"], "singles_win", as: "winner") do
    total *= 2 :: "Jokerless hand"
  end
end

on after_win do
  modify_winner("score", "hand_score")
end

on before_win do
  make_responsible_for("others")
  set_counter("jokers", "count_matches", ["hand", "calls", "winning_tile"], ~m"nojoker, dismantle_calls, 1j:1")
  set_counter_all("jokers", "jokers")
end

define_play_restriction "any", anyone_status("declare_shimocha_dead") or anyone_status("declare_toimen_dead") or anyone_status("declare_kamicha_dead")
define_play_restriction "any", status("dead_hand")

def blind_pass_left do
  as ["east", "north", "west", "south"] do
    cond do 
      to_pass == 3 ->
        set_status("pass_3")
      to_pass == 2 ->
        set_status("pass_2")
      to_pass == 1 ->
        set_status("pass_1")
      to_pass <= 0 -> noop
      true -> print("ERROR invalid value for to_pass")
    end
    subtract_counter("to_pass", "count_draws", "self")
    cond do 
      status("pass_3") ->
        pass_draws("kamicha", 3)
      status("pass_2") ->
        pass_draws("kamicha", 2)
      status("pass_1") ->
        pass_draws("kamicha", 1)
      true -> noop
    end
    unset_status("pass_1", "pass_2", "pass_3")
  end
end

def blind_pass_right do
  as ["east", "south", "west", "north"] do
    cond do 
      to_pass == 3 ->
        set_status("pass_3")
      to_pass == 2 ->
        set_status("pass_2")
      to_pass == 1 ->
        set_status("pass_1")
      to_pass <= 0 -> noop
      true -> print("ERROR invalid value for to_pass")
    end
    subtract_counter("to_pass", "count_draws", "self")
    cond do 
      status("pass_3") ->
        pass_draws("shimocha", 3)
      status("pass_2") ->
        pass_draws("shimocha", 2)
      status("pass_1") ->
        pass_draws("shimocha", 1)
      true -> noop
    end
    unset_status("pass_1", "pass_2", "pass_3")
  end
end

on before_turn_change do
  if status_missing("match_start") do
    unset_status("first_turn")
  end
end

on after_turn_change do
  if no_tiles_remaining do
    pause(1000)
    ryuukyoku
  end
  if status("dead_hand") do
    advance_turn
  else
    unless no_tiles_remaining do
      draw
    end
  end
end

on after_start do
  set_status_all("match_start", "first_charleston", "charleston_right", "heavenly_available")
  set_tile_alias_all(["1j"], [["1j", "_unpassable"], "any"])
  set_tile_alias_all(["2f", "3f", "4f", "1g", "2g", "3g", "4g"], ["1f"])
  # compute how many tiles in each player's hand are passable
  as everyone do
    set_counter("passables", "count_matches", ["hand", "draw"], ~m"any:1")
    subtract_counter("passables", "count_matches", ["hand", "draw"], ~m"(any@unpassable):1")
  end
end

on after_charleston do
  if status("blind_pass_left") do
    unset_status_all("blind_pass_left")
    as everyone do delete_tiles(%{hand: ["1x"], draw: ["1x"]}) end
    as everyone do
      set_counter("to_pass", 3)
      subtract_counter("to_pass", "count_draws", "kamicha")
    end
    blind_pass_left
    blind_pass_left
    blind_pass_left
    blind_pass_left
  end
  if status("blind_pass_right") do
    unset_status_all("blind_pass_right")
    as everyone do delete_tiles(%{hand: ["1x"], draw: ["1x"]}) end
    as everyone do
      set_counter("to_pass", 3)
      subtract_counter("to_pass", "count_draws", "shimocha")
    end
    blind_pass_right
    blind_pass_right
    blind_pass_right
    blind_pass_right
  end
  if anyone_status("start_blind_pass", "charleston_left") do
    unset_status_all("start_blind_pass")
    push_system_message("Select any number of the upside-down tiles to blind-pass that many tiles")
    set_status_all("blind_pass_left")
  end
  if anyone_status("start_blind_pass", "charleston_right") do
    unset_status_all("start_blind_pass")
    push_system_message("Select any number of the upside-down tiles to blind-pass that many tiles")
    set_status_all("blind_pass_right")
  end
end



define_button charleston_left,
  display_name: "Select three tiles to pass left",
  show_when: passables >= 3 and status("charleston_left"),
  unskippable: true,
  cancellable: false
  do
    mark [["hand", 3, ["self", "not_joker"]]] do
      unset_status("charleston_left", "heavenly_available")
      merge_draw
      sort_hand
      if status("blind_pass_left") do draw(3, "1x") end
    end
    charleston_left
    if status("first_charleston") do unset_status("first_charleston"); set_status("decide_charleston") end
    if status("second_charleston") do set_status("charleston_across") end
  end

define_button charleston_across,
  display_name: "Select three tiles to pass across",
  show_when: passables >= 3 and status("charleston_across"),
  unskippable: true,
  cancellable: false
  do
    mark [["hand", 3, ["self", "not_joker"]]] do
      unset_status("charleston_across", "heavenly_available")
      merge_draw
      sort_hand
    end
    charleston_across
    if status("first_charleston") do set_status("charleston_left") end
    if status("second_charleston") do set_status("charleston_right") end
    set_status("start_blind_pass")
  end

define_button charleston_right,
  display_name: "Select three tiles to pass right",
  show_when: passables >= 3 and status("charleston_right"),
  unskippable: true,
  cancellable: false
  do
    mark [["hand", 3, ["self", "not_joker"]]] do
      unset_status("charleston_right", "heavenly_available")
      merge_draw
      sort_hand
      if status("blind_pass_right") do draw(3, "1x") end
    end
    charleston_right
    if status("first_charleston") do set_status("charleston_across") end
    if status("second_charleston") do unset_status("second_charleston"); set_status("final_charleston") end
  end

define_button continue_charleston,
  display_name: "Continue Charleston",
  show_when: passables >= 3 and status("decide_charleston") and not_anyone_status("first_charleston"),
  unskippable: true
  do
    unset_status("decide_charleston")
    set_status("second_charleston", "charleston_left")
    if not_anyone_status("decide_charleston") and not_anyone_status("final_charleston") do
      set_status_all("second_charleston", "charleston_left")
      recalculate_buttons
    end
  end

define_button skip_charleston,
  display_name: "Skip Charleston",
  show_when: passables >= 3 and status("decide_charleston"),
  precedence_over: ["continue_charleston"],
  unskippable: true
  do
    big_text("Skip")
    unset_status_all("decide_charleston")
    set_status_all("final_charleston")
    recalculate_buttons
  end

define_button final_charleston_offer_0,
  display_name: "Offer 0",
  show_when: status("final_charleston") and status_missing("charleston_across_0", "charleston_across_1", "charleston_across_2", "charleston_across_3"),
  unskippable: true
  do
    big_text("Offer 0")
    set_status("final_charleston", "charleston_across_0")
    as toimen do
      if status("charleston_across_1") do unset_status("charleston_across_1"); set_status("charleston_across_0") end
      if status("charleston_across_2") do unset_status("charleston_across_2"); set_status("charleston_across_0") end
      if status("charleston_across_3") do unset_status("charleston_across_3"); set_status("charleston_across_0") end
    end
    recalculate_buttons
  end

define_button final_charleston_offer_1,
  display_name: "Offer 1",
  show_when: passables >= 1 and status("final_charleston") and status_missing("charleston_across_0", "charleston_across_1", "charleston_across_2", "charleston_across_3"),
  unskippable: true
  do
    big_text("Offer 1")
    set_status("final_charleston", "charleston_across_1")
    as toimen do
      if status("charleston_across_0") do unset_status("charleston_across_1", as: "prev_seat"); set_status("charleston_across_0", as: "prev_seat") end
      if status("charleston_across_2") do unset_status("charleston_across_2"); set_status("charleston_across_1") end
      if status("charleston_across_3") do unset_status("charleston_across_3"); set_status("charleston_across_1") end
    end
    recalculate_buttons
  end

