{
  "score_calculation": {
    "scoring_method": "multiplier",
    "discarder_multiplier": 2,
    "non_discarder_multiplier": 1,
    "self_draw_multiplier": 2,
    "yaku_lists": ["yaku"],
    "use_smt": false,
    "highest_scoring_yaku_only": true,
    "arrange_american_yaku": true,
    "point_name": "Pts",
    "win_by_discard_label": "Discard",
    "win_by_draw_label": "Draw",
    "win_by_discard_name": "Mah Jongg",
    "win_by_draw_name": "Mah Jongg",
    "exhaustive_draw_name": "Draw"
  },
  "play_restrictions": [
    [["any"], [[{"name": "anyone_status", "opts": ["declare_shimocha_dead"]}, {"name": "anyone_status", "opts": ["declare_toimen_dead"]}, {"name": "anyone_status", "opts": ["declare_kamicha_dead"]}]]],
    [["any"], [{"name": "status", "opts": ["dead_hand"]}]]
  ],
  "functions": {
    "blind_pass_left": [
      ["as", ["east", "north", "west", "south"], [
        ["when", [{"name": "counter_at_least", "opts": ["to_pass", 1]}], [["set_status", "pass_1"]]],
        ["when", [{"name": "counter_at_least", "opts": ["to_pass", 2]}], [["set_status", "pass_2"]]],
        ["when", [{"name": "counter_at_least", "opts": ["to_pass", 3]}], [["set_status", "pass_3"]]],
        ["subtract_counter", "to_pass", "count_draws", "self"],
        ["when", [{"name": "status", "opts": ["pass_1"]}], [["pass_draws", "kamicha", 1]]],
        ["when", [{"name": "status", "opts": ["pass_2"]}], [["pass_draws", "kamicha", 1]]],
        ["when", [{"name": "status", "opts": ["pass_3"]}], [["pass_draws", "kamicha", 1]]],
        ["unset_status", "pass_1", "pass_2", "pass_3"]
      ]]
    ],
    "blind_pass_right": [
      ["as", ["east", "south", "west", "north"], [
        ["when", [{"name": "counter_at_least", "opts": ["to_pass", 1]}], [["set_status", "pass_1"]]],
        ["when", [{"name": "counter_at_least", "opts": ["to_pass", 2]}], [["set_status", "pass_2"]]],
        ["when", [{"name": "counter_at_least", "opts": ["to_pass", 3]}], [["set_status", "pass_3"]]],
        ["subtract_counter", "to_pass", "count_draws", "self"],
        ["when", [{"name": "status", "opts": ["pass_1"]}], [["pass_draws", "shimocha", 1]]],
        ["when", [{"name": "status", "opts": ["pass_2"]}], [["pass_draws", "shimocha", 1]]],
        ["when", [{"name": "status", "opts": ["pass_3"]}], [["pass_draws", "shimocha", 1]]],
        ["unset_status", "pass_1", "pass_2", "pass_3"]
      ]]
    ]
  },
  "before_turn_change": {
    "actions": [
      ["when", [{"name": "status_missing", "opts": ["match_start"]}], [["unset_status", "first_turn"]]]
    ]
  },
  "after_turn_change": {
    "actions": [
      ["when", ["no_tiles_remaining"], [["pause", 1000], ["ryuukyoku"]]],
      // if dead hand, skip your turn, otherwise, draw a tile
      ["ite", [{"name": "status", "opts": ["dead_hand"]}], [["advance_turn"]], [
        ["when", ["not_no_tiles_remaining"], [["draw"]]]
      ]]
    ]
  },
  "after_start": {
    "actions": [
      ["set_status_all", "match_start", "first_charleston", "charleston_right", "heavenly_available"],
      ["set_tile_alias_all", ["1j"], [["1j", "_unpassable"], "any"]],
      ["set_tile_alias_all", ["2f", "3f", "4f", "1g", "2g", "3g", "4g"], ["1f"]],
        // compute how many tiles in each player's hand are passable
      ["as", "all", [
        ["set_counter", "passables", "count_matches", ["hand", "draw"], [[[[["any"]], 1]]]],
        ["subtract_counter", "passables", "count_matches", ["hand", "draw"], [[[[{"tile": "any", "attrs": ["unpassable"]}], 1]]]]
      ]]
    ]
  },
  "after_charleston": {
    "actions": [
      ["when", [{"name": "status", "opts": ["blind_pass_left"]}], [
        ["unset_status_all", "blind_pass_left"],
        ["as", "everyone", [["delete_tiles", {"hand": ["1x"], "draw": ["1x"]}]]],
        ["as", "everyone", [
          ["set_counter", "to_pass", 3],
          ["subtract_counter", "to_pass", "count_draws", "kamicha"]
        ]],
        ["run", "blind_pass_left"],
        ["run", "blind_pass_left"],
        ["run", "blind_pass_left"],
        ["run", "blind_pass_left"]
      ]],
      ["when", [{"name": "status", "opts": ["blind_pass_right"]}], [
        ["unset_status_all", "blind_pass_right"],
        ["as", "everyone", [["delete_tiles", {"hand": ["1x"], "draw": ["1x"]}]]],
        ["as", "everyone", [
          ["set_counter", "to_pass", 3],
          ["subtract_counter", "to_pass", "count_draws", "shimocha"]
        ]],
        ["run", "blind_pass_right"],
        ["run", "blind_pass_right"],
        ["run", "blind_pass_right"],
        ["run", "blind_pass_right"]
      ]],
      ["when", [{"name": "anyone_status", "opts": ["start_blind_pass", "charleston_left"]}], [
        ["unset_status_all", "start_blind_pass"],
        ["push_system_message", "Select any number of the upside-down tiles to blind-pass that many tiles"],
        ["set_status_all", "blind_pass_left"]
      ]],
      ["when", [{"name": "anyone_status", "opts": ["start_blind_pass", "charleston_right"]}], [
        ["unset_status_all", "start_blind_pass"],
        ["push_system_message", "Select any number of the upside-down tiles to blind-pass that many tiles"],
        ["set_status_all", "blind_pass_right"]
      ]]
    ]
  },
  "after_scoring": {
    "actions": [
      // jokerless bonus
      ["when", [
        {"name": "not_match", "opts": [["hand", "call_tiles", "winning_tile"], [[[["1j"], 1]]]]},
        {"name": "not_match", "opts": [["hand", "call_tiles", "winning_tile"], ["singles_win"]]}
      ], [
        ["push_message", "gets double score for a jokerless hand"],
        ["modify_payout", "all", 2, "multiply"]
      ]]
    ]
  },
  "buttons": {
    "charleston_left": {
      "display_name": "Select three tiles to pass left",
      "show_when": [{"name": "counter_at_least", "opts": ["passables", 3]}, {"name": "status", "opts": ["charleston_left"]}],
      "actions": [
        ["mark", [["hand", 3, ["self", "not_joker"]]], [
          ["unset_status", "charleston_left", "heavenly_available"],
          ["merge_draw"],
          ["sort_hand"],
          ["when", [{"name": "status", "opts": ["blind_pass_left"]}], [["draw", 3, "1x"]]]
        ]],
        ["charleston_left"],
        ["when", [{"name": "status", "opts": ["first_charleston"]}], [["unset_status", "first_charleston"], ["set_status", "decide_charleston"]]],
        ["when", [{"name": "status", "opts": ["second_charleston"]}], [["set_status", "charleston_across"]]]
      ],
      "unskippable": true,
      "cancellable": false
    },
    "charleston_across": {
      "display_name": "Select three tiles to pass across",
      "show_when": [{"name": "counter_at_least", "opts": ["passables", 3]}, {"name": "status", "opts": ["charleston_across"]}],
      "actions": [
        ["mark", [["hand", 3, ["self", "not_joker"]]], [["unset_status", "charleston_across", "heavenly_available"], ["merge_draw"], ["sort_hand"]]],
        ["charleston_across"],
        ["when", [{"name": "status", "opts": ["first_charleston"]}], [["set_status", "charleston_left"]]],
        ["when", [{"name": "status", "opts": ["second_charleston"]}], [["set_status", "charleston_right"]]],
        ["set_status", "start_blind_pass"]
      ],
      "unskippable": true,
      "cancellable": false
    },
    "charleston_right": {
      "display_name": "Select three tiles to pass right",
      "show_when": [{"name": "counter_at_least", "opts": ["passables", 3]}, {"name": "status", "opts": ["charleston_right"]}],
      "actions": [
        ["mark", [["hand", 3, ["self", "not_joker"]]], [
          ["unset_status", "charleston_right", "heavenly_available"],
          ["merge_draw"],
          ["sort_hand"],
          ["when", [{"name": "status", "opts": ["blind_pass_right"]}], [["draw", 3, "1x"]]]
        ]],
        ["charleston_right"],
        ["when", [{"name": "status", "opts": ["first_charleston"]}], [["set_status", "charleston_across"]]],
        ["when", [{"name": "status", "opts": ["second_charleston"]}], [["unset_status", "second_charleston"], ["set_status", "final_charleston"]]]
      ],
      "unskippable": true,
      "cancellable": false
    },
    "continue_charleston": {
      "display_name": "Continue Charleston",
      "show_when": [{"name": "counter_at_least", "opts": ["passables", 3]}, {"name": "status", "opts": ["decide_charleston"]}, {"name": "not_anyone_status", "opts": ["first_charleston"]}],
      "actions": [
        ["unset_status", "decide_charleston"],
        ["set_status", "second_charleston", "charleston_left"],
        ["when", [{"name": "not_anyone_status", "opts": ["decide_charleston"]}, {"name": "not_anyone_status", "opts": ["final_charleston"]}], [["set_status_all", "second_charleston", "charleston_left"], ["recalculate_buttons"]]]
      ],
      "unskippable": true
    },
    "skip_charleston": {
      "display_name": "Skip Charleston",
      "show_when": [{"name": "counter_at_least", "opts": ["passables", 3]}, {"name": "status", "opts": ["decide_charleston"]}],
      "actions": [
        ["big_text", "Skip"],
        ["unset_status_all", "decide_charleston"],
        ["set_status_all", "final_charleston"],
        ["recalculate_buttons"]
      ],
      "precedence_over": ["continue_charleston"],
      "unskippable": true
    },
    "final_charleston_offer_0": {
      "display_name": "Offer 0",
      "show_when": [{"name": "status", "opts": ["final_charleston"]}, {"name": "status_missing", "opts": ["charleston_across_0", "charleston_across_1", "charleston_across_2", "charleston_across_3"]}],
      "actions": [
        ["big_text", "Offer 0"],
        ["set_status", "final_charleston", "charleston_across_0"],
        ["when", [{"name": "toimen_status", "opts": ["charleston_across_1"]}], [["as", "toimen", [["unset_status", "charleston_across_1"], ["set_status", "charleston_across_0"]]]]],
        ["when", [{"name": "toimen_status", "opts": ["charleston_across_2"]}], [["as", "toimen", [["unset_status", "charleston_across_2"], ["set_status", "charleston_across_0"]]]]],
        ["when", [{"name": "toimen_status", "opts": ["charleston_across_3"]}], [["as", "toimen", [["unset_status", "charleston_across_3"], ["set_status", "charleston_across_0"]]]]],
        ["recalculate_buttons"]
      ],
      "unskippable": true
    },
    "final_charleston_offer_1": {
      "display_name": "Offer 1",
      "show_when": [{"name": "counter_at_least", "opts": ["passables", 1]}, {"name": "status", "opts": ["final_charleston"]}, {"name": "status_missing", "opts": ["charleston_across_0", "charleston_across_1", "charleston_across_2", "charleston_across_3"]}],
      "actions": [
        ["big_text", "Offer 1"],
        ["set_status", "final_charleston", "charleston_across_1"],
        ["when", [{"name": "toimen_status", "opts": ["charleston_across_0"]}], [["unset_status", "charleston_across_1"], ["set_status", "charleston_across_0"]]],
        ["when", [{"name": "toimen_status", "opts": ["charleston_across_2"]}], [["as", "toimen", [["unset_status", "charleston_across_2"], ["set_status", "charleston_across_1"]]]]],
        ["when", [{"name": "toimen_status", "opts": ["charleston_across_3"]}], [["as", "toimen", [["unset_status", "charleston_across_3"], ["set_status", "charleston_across_1"]]]]],
        ["recalculate_buttons"]
      ],
      "unskippable": true
    },
    "final_charleston_offer_2": {
      "display_name": "Offer 2",
      "show_when": [{"name": "counter_at_least", "opts": ["passables", 2]}, {"name": "status", "opts": ["final_charleston"]}, {"name": "status_missing", "opts": ["charleston_across_0", "charleston_across_1", "charleston_across_2", "charleston_across_3"]}],
      "actions": [
        ["big_text", "Offer 2"],
        ["set_status", "final_charleston", "charleston_across_2"],
        ["when", [{"name": "toimen_status", "opts": ["charleston_across_0"]}], [["unset_status", "charleston_across_2"], ["set_status", "charleston_across_0"]]],
        ["when", [{"name": "toimen_status", "opts": ["charleston_across_1"]}], [["unset_status", "charleston_across_2"], ["set_status", "charleston_across_1"]]],
        ["when", [{"name": "toimen_status", "opts": ["charleston_across_3"]}], [["as", "toimen", [["unset_status", "charleston_across_3"], ["set_status", "charleston_across_2"]]]]],
        ["recalculate_buttons"]
      ],
      "unskippable": true
    },
    "final_charleston_offer_3": {
      "display_name": "Offer 3",
      "show_when": [{"name": "counter_at_least", "opts": ["passables", 3]}, {"name": "status", "opts": ["final_charleston"]}, {"name": "status_missing", "opts": ["charleston_across_0", "charleston_across_1", "charleston_across_2", "charleston_across_3"]}],
      "actions": [
        ["big_text", "Offer 3"],
        ["set_status", "final_charleston", "charleston_across_3"],
        ["when", [{"name": "toimen_status", "opts": ["charleston_across_0"]}], [["unset_status", "charleston_across_3"], ["set_status", "charleston_across_0"]]],
        ["when", [{"name": "toimen_status", "opts": ["charleston_across_1"]}], [["unset_status", "charleston_across_3"], ["set_status", "charleston_across_1"]]],
        ["when", [{"name": "toimen_status", "opts": ["charleston_across_2"]}], [["unset_status", "charleston_across_3"], ["set_status", "charleston_across_2"]]],
        ["recalculate_buttons"]
      ],
      "unskippable": true
    },
    "charleston_across_0": {
      "display_name": "Pass no tiles across",
      "show_when": [{"name": "status", "opts": ["final_charleston", "charleston_across_0"]}, {"name": "toimen_status", "opts": ["final_charleston", "charleston_across_0"]}],
      "actions": [
        ["unset_status", "final_charleston", "charleston_across_0"],
        ["when", [{"name": "not_anyone_status", "opts": ["final_charleston"]}], [["unset_status_all", "match_start"]]],
        ["recalculate_buttons"]
      ],
      "unskippable": true,
      "cancellable": false
    },
    "charleston_across_1": {
      "display_name": "Select a tile to pass across",
      "show_when": [{"name": "counter_at_least", "opts": ["passables", 1]}, {"name": "status", "opts": ["final_charleston", "charleston_across_1"]}, {"name": "toimen_status", "opts": ["final_charleston", "charleston_across_1"]}],
      "actions": [
        ["mark", [["hand", 1, ["self", "not_joker"]]], [["unset_status", "charleston_across_1"]]],
        ["charleston_across"],
        ["unset_status", "final_charleston"],
        ["when", [{"name": "not_anyone_status", "opts": ["final_charleston"]}], [["unset_status_all", "match_start"]]]
      ],
      "unskippable": true,
      "cancellable": false
    },
    "charleston_across_2": {
      "display_name": "Select two tiles to pass across",
      "show_when": [{"name": "counter_at_least", "opts": ["passables", 2]}, {"name": "status", "opts": ["final_charleston", "charleston_across_2"]}, {"name": "toimen_status", "opts": ["final_charleston", "charleston_across_2"]}],
      "actions": [
        ["mark", [["hand", 2, ["self", "not_joker"]]], [["unset_status", "charleston_across_2"]]],
        ["charleston_across"],
        ["unset_status", "final_charleston"],
        ["when", [{"name": "not_anyone_status", "opts": ["final_charleston"]}], [["unset_status_all", "match_start"]]]
      ],
      "unskippable": true,
      "cancellable": false
    },
    "charleston_across_3": {
      "display_name": "Select three tiles to pass across",
      "show_when": [{"name": "counter_at_least", "opts": ["passables", 3]}, {"name": "status", "opts": ["final_charleston", "charleston_across_3"]}, {"name": "toimen_status", "opts": ["final_charleston", "charleston_across_3"]}],
      "actions": [
        ["mark", [["hand", 3, ["self", "not_joker"]]], [["unset_status", "charleston_across_3"]]],
        ["charleston_across"],
        ["unset_status", "final_charleston"],
        ["when", [{"name": "not_anyone_status", "opts": ["final_charleston"]}], [["unset_status_all", "match_start"]]]
      ],
      "unskippable": true,
      "cancellable": false
    },
      // TODO: check that this button behaves the way it should. this button is here for any variants where a player has so many unpassable tiles (e.g. jokers, blanks, flowers in older NMJL rules) that they are unable to pass three tiles during the Charleston.
      // TODO: need some kind of test scenario to check if this button works correctly
    "abort_during_charleston": {
      "display_name": "Can't pass three tiles",
      "show_when": [{"name": "status", "opts": ["match_start"]}, {"name": "counter_less_than", "opts": ["passables", 3]}],
      "actions": [
        ["big_text", "Can't pass three tiles"],
        ["pause", 1500],
        ["abortive_draw", "Throw in all tiles and start again"]
      ],
      "unskippable": true,
      "cancellable": false,
      "precedence_over": ["charleston_left", "charleston_across", "charleston_right", "continue_charleston", "skip_charleston"]
    },
    "1_am_pung": {
      "display_name": "Pung",
      "call": [[0, 0]],
      "call_name": "am_pung",
      "call_conditions": [
        {"name": "hand_length_at_least", "opts": [3]},
        {"name": "not_called_tile_contains", "opts": [["1j"], 1]},
        {"name": "call_contains", "opts": [["1m","2m","3m","4m","5m","6m","7m","8m","9m","1p","2p","3p","4p","5p","6p","7p","8p","9p","1s","2s","3s","4s","5s","6s","7s","8s","9s","1z","2z","3z","4z","0z","6z","7z","1f","2f","3f","4f","1g","2g","3g","4g"], 1]}
      ],
      "show_when": [{"name": "status_missing", "opts": ["match_start", "dead_hand"]}, "not_our_turn", "not_no_tiles_remaining", "someone_else_just_discarded", "call_available"],
      "actions": [["big_text", "Pung"], ["call"], ["change_turn", "self"]],
      "precedence_over": ["am_pung", "am_kong", "am_quint"]
    },
    "2_am_kong": {
      "display_name": "Kong",
      "call": [[0, 0, 0]],
      "call_name": "am_kong",
      "call_conditions": [
        {"name": "hand_length_at_least", "opts": [4]},
        {"name": "not_called_tile_contains", "opts": [["1j"], 1]},
        {"name": "call_contains", "opts": [["1m","2m","3m","4m","5m","6m","7m","8m","9m","1p","2p","3p","4p","5p","6p","7p","8p","9p","1s","2s","3s","4s","5s","6s","7s","8s","9s","1z","2z","3z","4z","0z","6z","7z","1f","2f","3f","4f","1g","2g","3g","4g"], 1]}
      ],
      "show_when": [{"name": "status_missing", "opts": ["match_start", "dead_hand"]}, "not_our_turn", "not_no_tiles_remaining", "someone_else_just_discarded", "call_available"],
      "actions": [["big_text", "Kong"], ["call"], ["change_turn", "self"]],
      "precedence_over": ["am_pung", "am_kong", "am_quint"]
    },
    "3_am_quint": {
      "display_name": "Quint",
      "call": [[0, 0, 0, 0]],
      "call_name": "am_quint",
      "call_conditions": [
        {"name": "hand_length_at_least", "opts": [5]},
        {"name": "not_called_tile_contains", "opts": [["1j"], 1]},
        {"name": "call_contains", "opts": [["1m","2m","3m","4m","5m","6m","7m","8m","9m","1p","2p","3p","4p","5p","6p","7p","8p","9p","1s","2s","3s","4s","5s","6s","7s","8s","9s","1z","2z","3z","4z","0z","6z","7z","1f","2f","3f","4f","1g","2g","3g","4g"], 1]}
      ],
      "show_when": [{"name": "status_missing", "opts": ["match_start", "dead_hand"]}, "not_our_turn", "not_no_tiles_remaining", "someone_else_just_discarded", "call_available"],
      "actions": [["big_text", "Quint"], ["call"], ["change_turn", "self"]],
      "precedence_over": ["am_pung", "am_kong", "am_quint"]
    },
    "am_joker_swap": {
      "display_name": "Swap for exposed joker",
      "show_when": [
        {"name": "status_missing", "opts": ["match_start", "dead_hand"]},
        "our_turn", "not_just_discarded",
        {"name": "match", "opts": [["hand_draw_nonjoker_any", "anyone_joker_meld_tiles"], [[[["pair"], 1]]]]}
      ],
      "actions": [
        ["big_text", "Swap"],
        ["mark", [["call", 1, ["call_has_joker", "match_call_to_marked_hand"]], ["hand", 1, ["self", "not_joker", "match_hand_to_marked_call"]]]],
        ["swap_out_joker", "1j"]
      ]
    },
    "mahjong_heavenly": {
      "display_name": "Mah Jongg",
      "show_when": [
        {"name": "status", "opts": ["heavenly_available", "charleston_left"]}, "our_turn", "is_tenpai_american", {"name": "match", "opts": [["hand", "call_tiles", "draw"], ["win"]]}
      ],
      "actions": [
        ["big_text", "Mah Jongg"], ["pause", 1000], ["reveal_hand"], ["win_by_draw"]
      ],
      "precedence_over": ["1_am_pung", "2_am_kong", "3_am_quint", "abort_during_charleston"]
    },
    "mahjong_draw": {
      "display_name": "Mah Jongg",
      "show_when": [
        {"name": "status_missing", "opts": ["match_start", "dead_hand"]}, "our_turn", "has_draw", "is_tenpai_american",
        [
          {"name": "match", "opts": [["hand", "call_tiles", "draw"], ["open_win"]]},
          [
            {"name": "has_no_call_named", "opts": ["am_pung", "am_kong", "am_quint"]},
